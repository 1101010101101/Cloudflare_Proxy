<Window x:Class="CloudflareProxyApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cloudflare Proxy" Width="350" Height="610"
        MinWidth="350" MaxWidth="350" MinHeight="610" MaxHeight="610"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="True" Icon="Assets/cloudflare-proxy.ico">
    <Window.Resources>
        <SolidColorBrush x:Key="Ink" Color="#183247" />
        <SolidColorBrush x:Key="Muted" Color="#718799" />
        <SolidColorBrush x:Key="Blue" Color="#159FD6" />
        <SolidColorBrush x:Key="Green" Color="#1EBA91" />

        <Style TargetType="Button" x:Key="WindowButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#7690A2" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#E4F2FA" />
                                <Setter Property="Foreground" Value="#27495D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="ConnectButton">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#159FD6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="56" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="7" Padding="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#078DC3" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#087DA9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="B" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="DisconnectButton">
            <Setter Property="Foreground" Value="#385465" />
            <Setter Property="Background" Value="#E8F0F4" />
            <Setter Property="BorderBrush" Value="#D5E2E8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#FFF0F2" />
                                <Setter TargetName="B" Property="BorderBrush" Value="#F4CCD2" />
                                <Setter Property="Foreground" Value="#C94758" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#F9DEE2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="B" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock" x:Key="StageText">
            <Setter Property="Foreground" Value="#94A7B5" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,3" />
        </Style>

        <Style x:Key="SettingsSwitch" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#29485B" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Track" Width="36" Height="20" CornerRadius="10"
                                    Background="#C9D8E0" HorizontalAlignment="Left">
                                <Ellipse x:Name="Thumb" Width="16" Height="16" Fill="White" Margin="2"
                                         HorizontalAlignment="Left" />
                            </Border>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#159FD6" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.45" />
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsAction" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Border CornerRadius="15" Background="#F4FAFD" BorderBrush="#D7E7F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" ShadowDepth="5" Opacity="0.28" Color="#37566A" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Image Source="Assets/cloudflare-proxy.ico" Width="22" Height="22" />
                    <TextBlock Text="Cloudflare Proxy" Foreground="#6D7F8C" FontSize="12.5"
                               Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,6,0">
                    <Button Style="{StaticResource WindowButton}" Content="−" Click="Minimize_Click" />
                    <Button Style="{StaticResource WindowButton}" Content="×" Click="Close_Click" />
                </StackPanel>
            </Grid>

            <Grid x:Name="MainContent" Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="238" />
                    <RowDefinition x:Name="StageRow" Height="72" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="14,0">
                    <Button Width="36" Height="36" HorizontalAlignment="Left" VerticalAlignment="Center"
                            Style="{StaticResource WindowButton}" FontSize="22" Foreground="#159FD6"
                            Content="⚙" ToolTip="Настройки" Click="Settings_Click" />
                    <Border Width="26" Height="26" CornerRadius="13" Background="#E0F3FA"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="i" Foreground="#159FD6" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </Grid>

                <Grid Grid.Row="1" Margin="18,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="108" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Border x:Name="FlagPlate" Width="82" Height="58" CornerRadius="4"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                BorderBrush="#CCDCE5" BorderThickness="1" ClipToBounds="True" Visibility="Collapsed">
                            <Grid x:Name="FlagGrid" Background="White">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="FlagStripe1" Grid.Row="0" Grid.ColumnSpan="3" Background="#159FD6" />
                                <Border x:Name="FlagStripe2" Grid.Row="1" Grid.ColumnSpan="3" Background="White" />
                                <Border x:Name="FlagStripe3" Grid.Row="2" Grid.ColumnSpan="3" Background="#159FD6" />
                                <Canvas x:Name="SpecialFlagCanvas" Grid.RowSpan="3" Grid.ColumnSpan="3"
                                        Width="82" Height="58" Visibility="Collapsed" />
                                <TextBlock x:Name="FlagCodeOverlay" Grid.RowSpan="3" Grid.ColumnSpan="3"
                                           Text="--" FontWeight="Bold" FontSize="20" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" />
                            </Grid>
                        </Border>

                        <Grid x:Name="OfflineArtwork">
                            <Ellipse Width="84" Height="84" Fill="#E8F4F9" Stroke="#D5E8F0" StrokeThickness="1" />
                            <Viewbox Width="42" Height="42">
                                <Canvas Width="48" Height="48">
                                    <Path Stroke="#7191A3" StrokeThickness="3.5" StrokeStartLineCap="Round"
                                          Data="M24,5 L24,23" />
                                    <Path Stroke="#7191A3" StrokeThickness="3.5" StrokeStartLineCap="Round"
                                          Data="M14,10 C7,15 5,24 9,31 C13,40 24,44 33,39 C44,33 45,18 35,10" />
                                </Canvas>
                            </Viewbox>
                        </Grid>

                        <Grid x:Name="BusyArtwork" Visibility="Collapsed">
                            <Ellipse Width="84" Height="84" Fill="#E3F4FA" />
                            <Viewbox Width="44" Height="52">
                                <Canvas Width="48" Height="56">
                                    <Path Fill="#159FD6" Data="M24,1 L45,9 V27 C45,41 36,50 24,55 C12,50 3,41 3,27 V9 Z" />
                                    <Path Stroke="White" StrokeThickness="3" StrokeStartLineCap="Round"
                                          Data="M13,28 C16,21 24,18 32,21" />
                                    <Path Fill="White" Data="M34,17 L39,23 L31,25 Z" />
                                </Canvas>
                            </Viewbox>
                        </Grid>
                    </Grid>

                    <TextBlock x:Name="StatusTitle" Grid.Row="1" Text="Прокси выключен"
                               Foreground="{StaticResource Ink}" FontWeight="SemiBold" FontSize="18"
                               TextAlignment="Center" />

                    <Grid Grid.Row="2" Margin="0,7,0,0">
                        <TextBlock x:Name="StatusMessage" Text="Локальный SOCKS5 сейчас не принимает соединения"
                                   Foreground="{StaticResource Muted}" FontSize="11.5" TextAlignment="Center"
                                   TextWrapping="Wrap" VerticalAlignment="Top" Margin="8,0" />

                        <Grid x:Name="ConnectedFactsPanel" Visibility="Collapsed" VerticalAlignment="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Внешний IP" Foreground="#92A5B2" FontSize="10" TextAlignment="Center" />
                                <TextBox x:Name="ExitIpText" Text="определяю…" Foreground="#28485D"
                                         FontSize="12" FontWeight="SemiBold" TextAlignment="Center"
                                         Margin="4,2,4,0" Padding="0" BorderThickness="0"
                                         Background="Transparent" IsReadOnly="True" Cursor="IBeam"
                                         SelectionBrush="#159FD6" SelectionOpacity="0.35"
                                         GotKeyboardFocus="SelectableText_GotKeyboardFocus"
                                         MouseDoubleClick="SelectableText_MouseDoubleClick"
                                         ToolTip="Можно выделить и скопировать" />
                            </StackPanel>
                            <Border Grid.Column="1" Background="#D9E6EC" Margin="0,1,0,0" />
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Страна выхода" Foreground="#92A5B2" FontSize="10" TextAlignment="Center" />
                                <TextBlock x:Name="ExitCountryText" Text="определяю…" Foreground="#28485D"
                                           FontSize="12" FontWeight="SemiBold" TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis" Margin="4,3,4,0" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>

                <Border x:Name="EndpointCard" Grid.Row="2" Visibility="Collapsed" Background="White"
                        BorderBrush="#D7E7F0" BorderThickness="0,1,0,1" Padding="16,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Прокси:" Foreground="#8BA0AE" FontSize="11.5" VerticalAlignment="Center" />
                        <TextBox x:Name="EndpointText" Grid.Column="1" Text="127.0.0.1:1081 socks5"
                                 Foreground="#173449" FontFamily="Cascadia Mono" FontWeight="SemiBold"
                                 FontSize="11.5" Margin="10,0,0,0" Padding="0" BorderThickness="0"
                                 Background="Transparent" IsReadOnly="True" Cursor="IBeam"
                                 VerticalContentAlignment="Center" SelectionBrush="#159FD6"
                                 SelectionOpacity="0.35" GotKeyboardFocus="SelectableText_GotKeyboardFocus"
                                 MouseDoubleClick="SelectableText_MouseDoubleClick"
                                 ToolTip="Можно выделить и скопировать" />
                        <Button Grid.Column="2" Style="{StaticResource WindowButton}" Content="⧉"
                                ToolTip="Скопировать" Foreground="#159FD6" Click="CopyEndpoint_Click" />
                    </Grid>
                </Border>

                <Border x:Name="StagePanel" Grid.Row="2" Background="White" BorderBrush="#D7E7F0"
                        BorderThickness="0,1,0,1" Padding="16,8" Visibility="Collapsed">
                    <StackPanel>
                        <ProgressBar x:Name="ProgressValue" Minimum="0" Maximum="100" Value="0" Height="4"
                                     Foreground="#159FD6" Background="#E5F0F5" BorderThickness="0" />
                        <UniformGrid Rows="2" Columns="3" Margin="0,6,0,0">
                            <TextBlock x:Name="StageCheck" Text="○  Проверка" Style="{StaticResource StageText}" />
                            <TextBlock x:Name="StageGithub" Text="○  GitHub" Style="{StaticResource StageText}" />
                            <TextBlock x:Name="StageWorkflow" Text="○  Workflow" Style="{StaticResource StageText}" />
                            <TextBlock x:Name="StageRunner" Text="○  Runner" Style="{StaticResource StageText}" />
                            <TextBlock x:Name="StageTunnel" Text="○  Tunnel" Style="{StaticResource StageText}" />
                            <TextBlock x:Name="StageLocal" Text="○  SOCKS5" Style="{StaticResource StageText}" />
                        </UniformGrid>
                        <Border x:Name="GithubAuthPanel" Visibility="Collapsed" Margin="0,8,0,1"
                                Padding="10,8" CornerRadius="6" Background="#EAF6FB"
                                BorderBrush="#B9DDEA" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Код подтверждения GitHub" Foreground="#61798A"
                                           FontSize="10.5" Margin="0,0,0,5" />
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="GithubAuthCodeText" IsReadOnly="True"
                                             Background="Transparent" BorderThickness="0" Padding="0"
                                             Foreground="#173449" FontFamily="Cascadia Mono" FontSize="15"
                                             FontWeight="Bold" VerticalContentAlignment="Center"
                                             SelectionBrush="#159FD6" SelectionOpacity="0.35"
                                             GotKeyboardFocus="SelectableText_GotKeyboardFocus"
                                             MouseDoubleClick="SelectableText_MouseDoubleClick" />
                                    <Button x:Name="CopyGithubCodeButton" Grid.Column="1"
                                            Content="Скопировать код" Click="CopyGithubCode_Click"
                                            Padding="10,4" Margin="8,0,0,0" Cursor="Hand"
                                            Foreground="White" Background="#159FD6" BorderThickness="0" />
                                </Grid>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="3" Margin="14,14,14,0">
                    <Button x:Name="StartButton" Style="{StaticResource ConnectButton}" Click="Start_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="➜" FontSize="17" Margin="0,-1,9,0" />
                            <TextBlock Text="Подключить прокси" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="StopButton" Style="{StaticResource DisconnectButton}"
                            Visibility="Collapsed" Click="Stop_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="●" Foreground="#D55464" FontSize="11" Margin="0,0,9,0" />
                            <TextBlock Text="Отключить прокси" />
                        </StackPanel>
                    </Button>
                </Grid>

                <Grid Grid.Row="4" Margin="16,8,16,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Expander x:Name="DetailsExpander" Grid.Row="0" Foreground="#718799" FontSize="11"
                              Header="Технические детали">
                        <Border Margin="0,6,0,0" Padding="8" CornerRadius="5" Background="#EAF4F8">
                            <TextBox x:Name="LogText" IsReadOnly="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" MaxHeight="70" Background="Transparent"
                                     BorderThickness="0" Foreground="#61798A" FontFamily="Cascadia Mono" FontSize="9.5" />
                        </Border>
                    </Expander>
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SessionTimeText" Grid.Column="0" Text="00:00:00"
                                   Foreground="#8196A5" FontSize="9.5" />
                        <TextBlock x:Name="LatencyText" Grid.Column="1" Text="пинг: —"
                                   Foreground="#657F90" FontSize="9.5" TextAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="2.1.1" Foreground="#8196A5" FontSize="9.5"
                                   TextAlignment="Right" />
                    </Grid>
                </Grid>
            </Grid>

            <Grid x:Name="SettingsPage" Grid.Row="1" Background="#F4FAFD"
                  Visibility="Collapsed" Panel.ZIndex="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="66" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="12,0">
                    <Button Width="36" Height="34" HorizontalAlignment="Left"
                            Style="{StaticResource WindowButton}" Content="←" FontSize="18"
                            ToolTip="Вернуться" Click="BackFromSettings_Click" />
                    <TextBlock Text="Настройки" Foreground="{StaticResource Ink}" FontSize="16"
                               FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="18,4,18,14">
                        <TextBlock Text="ЗАПУСК" Foreground="#8CA0AD" FontSize="10" FontWeight="SemiBold" />
                        <CheckBox x:Name="SettingsStartWithWindowsBox" Style="{StaticResource SettingsSwitch}"
                                  Content="Запускать вместе с Windows"
                                  Checked="EmbeddedStartup_Changed" Unchecked="EmbeddedStartup_Changed" />
                        <CheckBox x:Name="SettingsStartInTrayBox" Style="{StaticResource SettingsSwitch}"
                                  Content="При автозапуске открывать в трее" />
                        <CheckBox x:Name="SettingsConnectOnStartupBox" Style="{StaticResource SettingsSwitch}"
                                  Content="Подключать прокси после запуска" />

                        <Border Height="1" Background="#DCE8EE" Margin="0,11" />
                        <TextBlock Text="ЛОКАЛЬНЫЙ SOCKS5" Foreground="#8CA0AD" FontSize="10" FontWeight="SemiBold" />
                        <Grid Margin="0,9,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="96" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="IP-адрес" Foreground="#718799" FontSize="10.5" Margin="0,0,0,4" />
                                <ComboBox x:Name="SettingsListenAddressBox" Height="34" IsEditable="True"
                                          FontSize="11.5" Padding="7,5" Background="White"
                                          BorderBrush="#D5E3EA" SelectionChanged="EmbeddedAddress_Changed"
                                          LostKeyboardFocus="EmbeddedAddress_LostFocus">
                                    <ComboBoxItem Content="127.0.0.1" />
                                    <ComboBoxItem Content="0.0.0.0" />
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Порт" Foreground="#718799" FontSize="10.5" Margin="0,0,0,4" />
                                <TextBox x:Name="SettingsListenPortBox" Height="34" FontSize="11.5"
                                         Padding="8,7" Background="White" BorderBrush="#D5E3EA" />
                            </StackPanel>
                        </Grid>
                        <Border x:Name="EmbeddedNetworkWarning" Background="#FFF4DE" BorderBrush="#F1D7A1"
                                BorderThickness="1" CornerRadius="6" Padding="9" Margin="0,9,0,0"
                                Visibility="Collapsed">
                            <TextBlock Text="0.0.0.0 откроет прокси для локальной сети. Разрешайте доступ только доверенным устройствам."
                                       Foreground="#8A6525" FontSize="10" TextWrapping="Wrap" />
                        </Border>

                        <Border Height="1" Background="#DCE8EE" Margin="0,13,0,11" />
                        <TextBlock Text="ПОВЕДЕНИЕ" Foreground="#8CA0AD" FontSize="10" FontWeight="SemiBold" />
                        <CheckBox x:Name="SettingsShowNotificationsBox" Style="{StaticResource SettingsSwitch}"
                                  Content="Уведомлять при сворачивании" />
                        <CheckBox x:Name="SettingsCheckExitInfoBox" Style="{StaticResource SettingsSwitch}"
                                  Content="Определять IP, страну и задержку" />

                        <Button Content="Сбросить настройки" Height="34" Margin="0,12,0,0"
                                Background="Transparent" BorderBrush="#D5E3EA" Foreground="#718799"
                                Cursor="Hand" Click="ResetEmbeddedSettings_Click" />
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="2" Background="White" Margin="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Назад" Style="{StaticResource SettingsAction}"
                            Margin="16,11,0,11" Background="#EEF3F6" BorderBrush="#D8E3E9"
                            Foreground="#526C7B" Click="BackFromSettings_Click" />
                    <Button Grid.Column="2" Content="Сохранить" Style="{StaticResource SettingsAction}"
                            Margin="0,11,16,11" Background="#159FD6" BorderBrush="#159FD6"
                            Foreground="White" Click="SaveEmbeddedSettings_Click" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
